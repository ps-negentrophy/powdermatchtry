# Supabase (required for auth + database)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# For seed script (service role key - keep secret)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Auth: Enable "Email" provider in Supabase Dashboard > Authentication > Providers
# Run migration 003_profiles_auth.sql in Supabase SQL Editor after creating the project
